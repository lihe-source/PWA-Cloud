{
  "id": "./",
  "name": "雲匣 DriveDock",
  "short_name": "雲匣",
  "description": "免後端、直接連線 Google Drive 的跨裝置 PWA 檔案櫃",
  "lang": "zh-Hant",
  "dir": "ltr",
  "start_url": "./#files",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "orientation": "any",
  "background_color": "#fdfbf7",
  "theme_color": "#fdfbf7",
  "categories": [
    "productivity",
    "utilities"
  ],
  "icons": [
    {
      "src": "./icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "上傳檔案",
      "short_name": "上傳",
      "url": "./#files?upload=file",
      "icons": [
        {
          "src": "./icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "開啟相片圖庫",
      "short_name": "相片",
      "url": "./#photos",
      "icons": [
        {
          "src": "./icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ]
}
